@model List<Order>

@if (!Model.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-inbox fs-1 opacity-25"></i>
        <p class="mt-2">No orders in this category.</p>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">#</th>
                        <th>Food Item</th>
                        <th>Requester</th>
                        <th>Qty</th>
                        <th>Ordered</th>
                        <th>Status</th>
                        <th class="pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model.OrderByDescending(o => o.OrderedAt))
                    {
                        <tr>
                            <td class="ps-4 text-muted">#@order.Id</td>
                            <td>
                                <strong>@order.FoodListing?.FoodName</strong>
                                @if (!string.IsNullOrEmpty(order.Notes))
                                {
                                    <br /><small class="text-info fst-italic">"@order.Notes"</small>
                                }
                            </td>
                            <td>
                                <strong>@order.User?.FullName</strong>
                                @if (!string.IsNullOrEmpty(order.PickupAddress))
                                {
                                    <br /><small class="text-muted"><i class="bi bi-geo-alt me-1"></i>@order.PickupAddress</small>
                                }
                            </td>
                            <td><strong>@order.QuantityRequested</strong></td>
                            <td><small class="text-muted">@order.OrderedAt.ToString("MMM dd, HH:mm")</small></td>
                            <td>
                                <span class="badge @GetStatusClass(order.Status)">@order.Status</span>
                            </td>
                            <td class="pe-4">
                                <div class="d-flex gap-1 flex-wrap">
                                    <a asp-controller="Orders" asp-action="Details" asp-route-id="@order.Id"
                                       class="btn btn-sm btn-outline-secondary" title="View">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    @if (order.Status == OrderStatus.Pending)
                                    {
                                        <form asp-controller="Orders" asp-action="UpdateStatus" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@order.Id" />
                                            <input type="hidden" name="status" value="@OrderStatus.Confirmed" />
                                            <button class="btn btn-sm btn-success" title="Confirm">
                                                <i class="bi bi-check-lg"></i>
                                            </button>
                                        </form>
                                    }
                                    @if (order.Status == OrderStatus.Confirmed)
                                    {
                                        <form asp-controller="Orders" asp-action="UpdateStatus" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@order.Id" />
                                            <input type="hidden" name="status" value="@OrderStatus.ReadyForPickup" />
                                            <button class="btn btn-sm btn-primary" title="Ready for Pickup">
                                                <i class="bi bi-box-seam"></i>
                                            </button>
                                        </form>
                                    }
                                    @if (order.Status == OrderStatus.ReadyForPickup)
                                    {
                                        <form asp-controller="Orders" asp-action="UpdateStatus" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@order.Id" />
                                            <input type="hidden" name="status" value="@OrderStatus.Completed" />
                                            <button class="btn btn-sm btn-info" title="Complete">
                                                <i class="bi bi-check-all"></i>
                                            </button>
                                        </form>
                                    }
                                    @if (order.Status != OrderStatus.Completed && order.Status != OrderStatus.Cancelled)
                                    {
                                        <form asp-controller="Orders" asp-action="UpdateStatus" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@order.Id" />
                                            <input type="hidden" name="status" value="@OrderStatus.Cancelled" />
                                            <button class="btn btn-sm btn-outline-danger" title="Cancel"
                                                    data-confirm="Cancel this order?">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@functions {
    string GetStatusClass(OrderStatus s) => s switch {
        OrderStatus.Pending => "bg-warning text-dark",
        OrderStatus.Confirmed => "bg-info text-dark",
        OrderStatus.ReadyForPickup => "bg-primary",
        OrderStatus.Completed => "bg-success",
        OrderStatus.Cancelled => "bg-secondary",
        _ => "bg-secondary"
    };
}
