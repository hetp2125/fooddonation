@model List<Order>
@{
    ViewData["Title"] = "My Orders";
}

<div class="page-header">
    <div class="container">
        <div class="row align-items-center">
            <div class="col">
                <h1 class="fw-bold mb-1"><i class="bi bi-bag-check me-2"></i>My Orders</h1>
                <p class="mb-0 opacity-75">Track your food order history and status.</p>
            </div>
            <div class="col-auto">
                <a asp-controller="FoodListings" asp-action="Browse" class="btn btn-warning fw-bold">
                    <i class="bi bi-search me-2"></i>Browse More Food
                </a>
            </div>
        </div>
    </div>
</div>

<div class="container py-4">
    @if (!Model.Any())
    {
        <div class="empty-state card border-0 shadow-sm">
            <div class="empty-state-icon">🛒</div>
            <h5 class="mt-3 fw-bold">No orders yet</h5>
            <p class="text-muted">You haven't placed any food orders. Browse available donations to get started!</p>
            <a asp-controller="FoodListings" asp-action="Browse" class="btn btn-success">Browse Food</a>
        </div>
    }
    else
    {
        <!-- Summary stats -->
        <div class="row g-3 mb-4">
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm p-3 text-center">
                    <div class="fs-4">⏳</div>
                    <div class="h4 fw-bold text-warning mb-0">@Model.Count(o => o.Status == OrderStatus.Pending)</div>
                    <small class="text-muted">Pending</small>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm p-3 text-center">
                    <div class="fs-4">✅</div>
                    <div class="h4 fw-bold text-info mb-0">@Model.Count(o => o.Status == OrderStatus.Confirmed)</div>
                    <small class="text-muted">Confirmed</small>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm p-3 text-center">
                    <div class="fs-4">📦</div>
                    <div class="h4 fw-bold text-primary mb-0">@Model.Count(o => o.Status == OrderStatus.ReadyForPickup)</div>
                    <small class="text-muted">Ready for Pickup</small>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm p-3 text-center">
                    <div class="fs-4">🎉</div>
                    <div class="h4 fw-bold text-success mb-0">@Model.Count(o => o.Status == OrderStatus.Completed)</div>
                    <small class="text-muted">Completed</small>
                </div>
            </div>
        </div>

        <div class="row g-4">
            @foreach (var order in Model)
            {
                <div class="col-md-6 col-xl-4">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-header bg-white border-0 pt-3 d-flex justify-content-between align-items-start">
                            <div>
                                <h6 class="fw-bold mb-0">@order.FoodListing?.FoodName</h6>
                                <small class="text-muted">Order #@order.Id</small>
                            </div>
                            <span class="badge @GetStatusClass(order.Status)">@order.Status</span>
                        </div>
                        <div class="card-body pt-2">
                            <div class="d-flex flex-column gap-2">
                                <div class="d-flex align-items-center">
                                    <i class="bi bi-boxes text-success me-2"></i>
                                    <span>@order.QuantityRequested @order.FoodListing?.Unit requested</span>
                                </div>
                                <div class="d-flex align-items-center">
                                    <i class="bi bi-geo-alt text-danger me-2"></i>
                                    <small class="text-muted">@order.FoodListing?.Location</small>
                                </div>
                                <div class="d-flex align-items-center">
                                    <i class="bi bi-person text-secondary me-2"></i>
                                    <small class="text-muted">From: @order.FoodListing?.Donor?.FullName</small>
                                </div>
                                <div class="d-flex align-items-center">
                                    <i class="bi bi-clock text-info me-2"></i>
                                    <small class="text-muted">@order.OrderedAt.ToString("MMM dd, yyyy HH:mm")</small>
                                </div>
                                @if (!string.IsNullOrEmpty(order.Notes))
                                {
                                    <div class="d-flex align-items-start">
                                        <i class="bi bi-chat text-primary me-2 mt-1"></i>
                                        <small class="text-muted fst-italic">"@order.Notes"</small>
                                    </div>
                                }
                            </div>

                            <!-- Progress indicator -->
                            <div class="mt-3">
                                <div class="progress" style="height: 6px;">
                                    @{
                                        int progress = order.Status switch {
                                            OrderStatus.Pending => 25,
                                            OrderStatus.Confirmed => 50,
                                            OrderStatus.ReadyForPickup => 75,
                                            OrderStatus.Completed => 100,
                                            _ => 0
                                        };
                                        string barColor = order.Status == OrderStatus.Cancelled ? "danger" : "success";
                                    }
                                    <div class="progress-bar bg-@barColor" style="width: @progress%"></div>
                                </div>
                                <div class="d-flex justify-content-between mt-1">
                                    <small class="text-muted" style="font-size:.65rem">Ordered</small>
                                    <small class="text-muted" style="font-size:.65rem">Confirmed</small>
                                    <small class="text-muted" style="font-size:.65rem">Ready</small>
                                    <small class="text-muted" style="font-size:.65rem">Done</small>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-white border-0 d-flex gap-2 pb-3">
                            <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-eye me-1"></i>Details
                            </a>
                            @if (order.Status == OrderStatus.Pending)
                            {
                                <form asp-action="CancelOrder" asp-route-id="@order.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger"
                                            data-confirm="Cancel this order?">
                                        <i class="bi bi-x me-1"></i>Cancel
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@functions {
    string GetStatusClass(OrderStatus s) => s switch {
        OrderStatus.Pending => "bg-warning text-dark",
        OrderStatus.Confirmed => "bg-info text-dark",
        OrderStatus.ReadyForPickup => "bg-primary",
        OrderStatus.Completed => "bg-success",
        OrderStatus.Cancelled => "bg-secondary",
        _ => "bg-secondary"
    };
}
