@model UserDashboardViewModel
@{
    ViewData["Title"] = "My Dashboard";
}

<div class="page-header">
    <div class="container">
        <div class="row align-items-center">
            <div class="col">
                <h1 class="fw-bold mb-1"><i class="bi bi-house-heart me-2"></i>My Dashboard</h1>
                <p class="mb-0 opacity-75">Browse available food donations and manage your orders.</p>
            </div>
            <div class="col-auto d-flex gap-2">
                <a asp-controller="FoodListings" asp-action="Browse" class="btn btn-warning fw-bold">
                    <i class="bi bi-search me-2"></i>Browse Food
                </a>
                <a asp-controller="FoodListings" asp-action="Create" class="btn btn-outline-light">
                    <i class="bi bi-plus me-1"></i>Donate
                </a>
            </div>
        </div>
    </div>
</div>

<div class="container py-4">
    <!-- Stats -->
    <div class="row g-4 mb-4">
        <div class="col-sm-4">
            <div class="card stat-card shadow-sm p-4 border-start border-success border-4">
                <div class="d-flex align-items-center">
                    <div class="stat-icon bg-success bg-opacity-10 text-success me-3">
                        <i class="bi bi-bag-heart"></i>
                    </div>
                    <div>
                        <div class="h3 fw-bold mb-0 text-success">@Model.AvailableListings</div>
                        <small class="text-muted">Available Items</small>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-4">
            <div class="card stat-card shadow-sm p-4 border-start border-warning border-4">
                <div class="d-flex align-items-center">
                    <div class="stat-icon bg-warning bg-opacity-10 text-warning me-3">
                        <i class="bi bi-box"></i>
                    </div>
                    <div>
                        <div class="h3 fw-bold mb-0 text-warning">@Model.MyOrders</div>
                        <small class="text-muted">My Orders</small>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-4">
            <div class="card stat-card shadow-sm p-4 border-start border-info border-4">
                <div class="d-flex align-items-center">
                    <div class="stat-icon bg-info bg-opacity-10 text-info me-3">
                        <i class="bi bi-gift"></i>
                    </div>
                    <div>
                        <div class="h3 fw-bold mb-0 text-info">@Model.MyListings</div>
                        <small class="text-muted">My Donations</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Available Food -->
        <div class="col-lg-7">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-white border-0 pt-4 pb-0 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0"><i class="bi bi-grid me-2 text-success"></i>Available Food Near You</h5>
                    <a asp-controller="FoodListings" asp-action="Browse" class="btn btn-sm btn-outline-success">Browse All</a>
                </div>
                <div class="card-body">
                    @if (!Model.RecentListings.Any())
                    {
                        <div class="empty-state">
                            <div class="empty-state-icon">🥗</div>
                            <p class="text-muted mt-2">No available food listings right now.</p>
                        </div>
                    }
                    else
                    {
                        <div class="row g-3">
                            @foreach (var listing in Model.RecentListings)
                            {
                                <div class="col-sm-6">
                                    <div class="card food-card shadow-sm h-100">
                                        <div class="food-emoji-bg">
                                            @GetCategoryEmoji(listing.Category)
                                        </div>
                                        <div class="card-body p-3">
                                            <h6 class="fw-bold mb-1">@listing.FoodName</h6>
                                            @if (listing.Category != null)
                                            {
                                                <span class="category-chip mb-2 d-inline-block">@listing.Category</span>
                                            }
                                            <p class="text-muted small mb-2 text-truncate">@listing.Description</p>
                                            <div class="d-flex justify-content-between align-items-center">
                                                <small class="text-muted"><i class="bi bi-geo-alt me-1"></i>@listing.Location.Split(',')[0]</small>
                                                <small class="fw-bold text-success">@listing.Quantity @listing.Unit</small>
                                            </div>
                                        </div>
                                        <div class="card-footer bg-white border-0 pb-3 pt-0">
                                            <a asp-controller="FoodListings" asp-action="Details" asp-route-id="@listing.Id"
                                               class="btn btn-success btn-sm w-100">
                                                <i class="bi bi-eye me-1"></i>View & Order
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- My Orders -->
        <div class="col-lg-5">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-white border-0 pt-4 pb-0 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0"><i class="bi bi-bag me-2 text-warning"></i>My Recent Orders</h5>
                    <a asp-controller="Orders" asp-action="Index" class="btn btn-sm btn-outline-warning">View All</a>
                </div>
                <div class="card-body">
                    @if (!Model.MyRecentOrders.Any())
                    {
                        <div class="empty-state">
                            <div class="empty-state-icon">🛒</div>
                            <p class="text-muted mt-2">No orders yet. Browse and place your first order!</p>
                            <a asp-controller="FoodListings" asp-action="Browse" class="btn btn-success btn-sm">Browse Food</a>
                        </div>
                    }
                    else
                    {
                        @foreach (var order in Model.MyRecentOrders)
                        {
                            <div class="border rounded-3 p-3 mb-3">
                                <div class="d-flex justify-content-between">
                                    <div>
                                        <strong>@order.FoodListing?.FoodName</strong>
                                        <br /><small class="text-muted">Qty: @order.QuantityRequested</small>
                                        <br /><small class="text-muted">@order.OrderedAt.ToString("MMM dd, yyyy")</small>
                                    </div>
                                    <span class="badge @GetOrderStatusClass(order.Status) align-self-start">@order.Status</span>
                                </div>
                                <a asp-controller="Orders" asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-outline-secondary mt-2">
                                    View Details
                                </a>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@functions {
    string GetCategoryEmoji(string? cat) => cat switch {
        "Hot Meals" => "🍲", "Baked Goods" => "🍞", "Fresh Produce" => "🥦",
        "Pantry Items" => "🥫", "Grains" => "🌾", "Dairy" => "🧀",
        "Protein" => "🥩", "Beverages" => "🥤", _ => "🍱"
    };
    string GetOrderStatusClass(OrderStatus s) => s switch {
        OrderStatus.Pending => "bg-warning text-dark",
        OrderStatus.Confirmed => "bg-info text-dark",
        OrderStatus.ReadyForPickup => "bg-primary",
        OrderStatus.Completed => "bg-success",
        OrderStatus.Cancelled => "bg-secondary",
        _ => "bg-secondary"
    };
}
