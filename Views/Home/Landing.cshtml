@{
    ViewData["Title"] = "Welcome";
    Layout = "_Layout";
}

<div class="hero-section text-white">
    <div class="container py-5">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <span class="badge bg-white text-success fs-6 mb-3 px-3 py-2">
                    🌱 Community Food Sharing
                </span>
                <h1 class="fw-bold mb-4">Share Food,<br/>Spread <span class="text-warning">Kindness</span></h1>
                <p class="lead mb-4 opacity-90">
                    Connect surplus food with people who need it. Zero waste, maximum impact.
                    Join thousands of donors and recipients making a difference every day.
                </p>
                <div class="d-flex gap-3 flex-wrap">
                    <a asp-controller="Account" asp-action="Register" class="btn btn-warning btn-lg fw-bold px-4">
                        <i class="bi bi-heart me-2"></i>Start Donating
                    </a>
                    <a asp-controller="Account" asp-action="Login" class="btn btn-outline-light btn-lg px-4">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
                    </a>
                </div>
                <div class="mt-4 d-flex gap-4 text-white-50">
                    <small><i class="bi bi-check-circle text-warning me-1"></i>Free to use</small>
                    <small><i class="bi bi-check-circle text-warning me-1"></i>No food waste</small>
                    <small><i class="bi bi-check-circle text-warning me-1"></i>Community driven</small>
                </div>
            </div>
            <div class="col-lg-6 text-center mt-5 mt-lg-0">
                <div style="font-size: 8rem; line-height: 1; opacity: .9;">🥗</div>
                <div class="d-flex justify-content-center gap-3 mt-3" style="font-size: 3rem;">
                    <span>🍎</span><span>🥖</span><span>🥘</span><span>🥦</span>
                </div>
            </div>
        </div>
    </div>
</div>
<div class="hero-wave"></div>

<!-- Stats -->
<div class="container py-5">
    <div class="row g-4 text-center">
        <div class="col-md-4">
            <div class="card stat-card shadow-sm p-4">
                <div class="stat-icon bg-success bg-opacity-10 text-success mx-auto mb-3">
                    <i class="bi bi-people-fill"></i>
                </div>
                <h2 class="fw-bold text-success">500+</h2>
                <p class="text-muted mb-0">Active Donors</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card stat-card shadow-sm p-4">
                <div class="stat-icon bg-warning bg-opacity-10 text-warning mx-auto mb-3">
                    <i class="bi bi-bag-heart-fill"></i>
                </div>
                <h2 class="fw-bold text-warning">2,000+</h2>
                <p class="text-muted mb-0">Meals Shared</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card stat-card shadow-sm p-4">
                <div class="stat-icon bg-info bg-opacity-10 text-info mx-auto mb-3">
                    <i class="bi bi-geo-alt-fill"></i>
                </div>
                <h2 class="fw-bold text-info">50+</h2>
                <p class="text-muted mb-0">Locations Served</p>
            </div>
        </div>
    </div>
</div>

<!-- How It Works -->
<div class="bg-white py-5">
    <div class="container">
        <h2 class="text-center fw-bold mb-2">How It Works</h2>
        <p class="text-center text-muted mb-5">Simple steps to share or receive food</p>
        <div class="row g-4">
            <div class="col-md-4 text-center">
                <div class="bg-success bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width:70px;height:70px;font-size:1.8rem;">🔐</div>
                <h5 class="fw-bold">1. Create Account</h5>
                <p class="text-muted">Sign up as a donor (Admin) or recipient (Local User) in seconds.</p>
            </div>
            <div class="col-md-4 text-center">
                <div class="bg-warning bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width:70px;height:70px;font-size:1.8rem;">🍱</div>
                <h5 class="fw-bold">2. Post or Browse Food</h5>
                <p class="text-muted">Donors list surplus food; users browse available listings near them.</p>
            </div>
            <div class="col-md-4 text-center">
                <div class="bg-info bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width:70px;height:70px;font-size:1.8rem;">🤝</div>
                <h5 class="fw-bold">3. Connect & Pickup</h5>
                <p class="text-muted">Place an order, get confirmed, and pick up your food. Zero waste!</p>
            </div>
        </div>
    </div>
</div>

<!-- CTA -->
<div class="bg-success py-5 text-white text-center">
    <div class="container">
        <h2 class="fw-bold mb-3">Ready to Make a Difference?</h2>
        <p class="lead mb-4 opacity-90">Join our community and help reduce food waste today.</p>
        <a asp-controller="Account" asp-action="Register" class="btn btn-warning btn-lg fw-bold px-5">
            <i class="bi bi-arrow-right-circle me-2"></i>Get Started Free
        </a>
        <div class="mt-3">
            <small class="opacity-75">Demo: admin@fooddonation.com / Admin@123456</small>
        </div>
    </div>
</div>
