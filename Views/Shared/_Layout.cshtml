<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " – " : "")FoodShare</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="d-flex flex-column min-vh-100">

<nav class="navbar navbar-expand-lg navbar-dark bg-success shadow-sm">
    <div class="container">
        <a class="navbar-brand fw-bold fs-4" href="/">
            <i class="bi bi-heart-fill me-2"></i>FoodShare
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarMain">
            <ul class="navbar-nav me-auto">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-speedometer2 me-1"></i>Dashboard
                        </a>
                    </li>

                    @if (User.IsInRole("LocalUser"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="FoodListings" asp-action="Browse">
                                <i class="bi bi-search me-1"></i>Browse Food
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Orders" asp-action="Index">
                                <i class="bi bi-bag-check me-1"></i>My Orders
                            </a>
                        </li>
                    }

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="FoodListings" asp-action="Index">
                            <i class="bi bi-list-ul me-1"></i>My Listings
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="FoodListings" asp-action="Create">
                            <i class="bi bi-plus-circle me-1"></i>Donate Food
                        </a>
                    </li>

                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Orders" asp-action="Index">
                                <i class="bi bi-clipboard-check me-1"></i>Manage Orders
                            </a>
                        </li>
                    }
                }
            </ul>

            <ul class="navbar-nav ms-auto">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" data-bs-toggle="dropdown">
                            <span class="badge @(User.IsInRole("Admin") ? "bg-warning text-dark" : "bg-info text-dark") me-2">
                                @(User.IsInRole("Admin") ? "Admin" : "User")
                            </span>
                            <i class="bi bi-person-circle me-1"></i>@User.Identity.Name?.Split('@')[0]
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow">
                            <li>
                                <form asp-controller="Account" asp-action="Logout" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="dropdown-item text-danger">
                                        <i class="bi bi-box-arrow-right me-2"></i>Sign Out
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Account" asp-action="Login">
                            <i class="bi bi-box-arrow-in-right me-1"></i>Login
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-light btn-sm ms-2" asp-controller="Account" asp-action="Register">
                            Sign Up Free
                        </a>
                    </li>
                }
            </ul>
        </div>
    </div>
</nav>

<main class="flex-grow-1">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-0 rounded-0 border-0" role="alert">
            <div class="container">
                <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-0 rounded-0 border-0" role="alert">
            <div class="container">
                <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        </div>
    }

    @RenderBody()
</main>

<footer class="bg-dark text-light py-4 mt-auto">
    <div class="container text-center">
        <p class="mb-1">
            <i class="bi bi-heart-fill text-danger me-1"></i>
            <strong>FoodShare</strong> – Reducing food waste, feeding communities
        </p>
        <small class="text-muted">&copy; @DateTime.Now.Year FoodShare Platform</small>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
