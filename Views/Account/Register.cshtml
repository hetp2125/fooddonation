@model RegisterViewModel
@{
    ViewData["Title"] = "Create Account";
}

<div class="min-vh-100 d-flex align-items-center" style="background: linear-gradient(135deg, #e8f5e9 0%, #f0faf4 100%);">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="text-center mb-4">
                    <span style="font-size: 3rem;">🌱</span>
                    <h2 class="fw-bold mt-2">Join FoodShare</h2>
                    <p class="text-muted">Create your free account</p>
                </div>

                <div class="card form-card p-4">
                    <form asp-action="Register" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0"></div>

                        <div class="mb-3">
                            <label asp-for="FullName" class="form-label fw-semibold">Full Name</label>
                            <input asp-for="FullName" class="form-control" placeholder="Your full name" />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-semibold">Email Address</label>
                            <input asp-for="Email" class="form-control" placeholder="you@example.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Address" class="form-label fw-semibold">Address <span class="text-muted fw-normal">(optional)</span></label>
                            <input asp-for="Address" class="form-control" placeholder="Your address for pickups" />
                        </div>

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label fw-semibold">Password</label>
                            <input asp-for="Password" class="form-control" placeholder="Min. 6 characters" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ConfirmPassword" class="form-label fw-semibold">Confirm Password</label>
                            <input asp-for="ConfirmPassword" class="form-control" placeholder="Repeat password" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Role" class="form-label fw-semibold">Account Type</label>
                            <div class="row g-2">
                                <div class="col-6">
                                    <input type="radio" class="btn-check" name="Role" id="roleUser" value="LocalUser" checked />
                                    <label class="btn btn-outline-success w-100 py-3" for="roleUser">
                                        <i class="bi bi-person-check d-block fs-4 mb-1"></i>
                                        <strong>Local User</strong>
                                        <small class="d-block text-muted">Browse food & donations</small>
                                    </label>
                                </div>
                                <div class="col-6">
                                    <input type="radio" class="btn-check" name="Role" id="roleAdmin" value="Admin" />
                                    <label class="btn btn-outline-warning w-100 py-3" for="roleAdmin">
                                        <i class="bi bi-person-gear d-block fs-4 mb-1"></i>
                                        <strong>Admin/Donor</strong>
                                        <small class="d-block text-muted">Only post food donations</small>
                                    </label>
                                </div>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-success w-100 py-2 fw-bold">
                            <i class="bi bi-person-plus me-2"></i>Create Account
                        </button>
                    </form>

                    <hr class="my-4" />
                    <p class="text-center text-muted mb-0">
                        Already have an account?
                        <a asp-action="Login" class="text-success fw-semibold text-decoration-none">Sign in</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
