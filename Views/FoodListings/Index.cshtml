@model FoodListingIndexViewModel
@{
    ViewData["Title"] = "My Food Listings";
}

<div class="page-header">
    <div class="container">
        <div class="row align-items-center">
            <div class="col">
                <h1 class="fw-bold mb-1"><i class="bi bi-list-ul me-2"></i>My Food Listings</h1>
                <p class="mb-0 opacity-75">Manage the food donations you've posted.</p>
            </div>
            <div class="col-auto">
                <a asp-action="Create" class="btn btn-warning fw-bold">
                    <i class="bi bi-plus-circle me-2"></i>Post New Donation
                </a>
            </div>
        </div>
    </div>
</div>

<div class="container py-4">
    <!-- Search / Filter -->
    <div class="card border-0 shadow-sm mb-4 p-3">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-4">
                <input type="text" name="search" value="@Model.SearchTerm" class="form-control" placeholder="🔍 Search food name..." />
            </div>
            <div class="col-md-3">
                <select name="category" class="form-select">
                    <option value="">All Categories</option>
                    @foreach (var cat in Model.Categories)
                    {
                        <option value="@cat" selected="@(Model.Category == cat)">@cat</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <input type="text" name="location" value="@Model.Location" class="form-control" placeholder="📍 Filter by location..." />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-success w-100">Filter</button>
            </div>
        </form>
    </div>

    @if (!Model.Listings.Any())
    {
        <div class="empty-state card border-0 shadow-sm">
            <div class="empty-state-icon">🍱</div>
            <h5 class="mt-3 fw-bold">No listings found</h5>
            <p class="text-muted">You haven't posted any food donations yet, or none match your filters.</p>
            <a asp-action="Create" class="btn btn-success">Post Your First Donation</a>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">Food Item</th>
                                <th>Category</th>
                                <th>Quantity</th>
                                <th>Location</th>
                                <th>Expires</th>
                                <th>Status</th>
                                <th>Orders</th>
                                <th class="pe-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var listing in Model.Listings)
                            {
                                <tr class="@(listing.IsExpired ? "table-warning" : "")">
                                    <td class="ps-4">
                                        <strong>@listing.FoodName</strong>
                                        <br /><small class="text-muted text-truncate d-inline-block" style="max-width:200px">@listing.Description</small>
                                    </td>
                                    <td>
                                        @if (listing.Category != null)
                                        {
                                            <span class="category-chip">@listing.Category</span>
                                        }
                                        else { <span class="text-muted">—</span> }
                                    </td>
                                    <td><strong>@listing.Quantity</strong> <small class="text-muted">@listing.Unit</small></td>
                                    <td><small>@listing.Location</small></td>
                                    <td>
                                        @if (listing.IsExpired)
                                        {
                                            <span class="text-danger fw-bold"><i class="bi bi-exclamation-triangle me-1"></i>Expired</span>
                                        }
                                        else if (listing.ExpirationDate < DateTime.UtcNow.AddDays(3))
                                        {
                                            <span class="expiry-soon">@listing.ExpirationDate.ToString("MMM dd")</span>
                                        }
                                        else
                                        {
                                            <span class="expiry-ok">@listing.ExpirationDate.ToString("MMM dd, yyyy")</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge @GetStatusClass(listing.Status)">@listing.Status</span>
                                    </td>
                                    <td>
                                        <span class="badge bg-secondary rounded-pill">
                                            @listing.Orders.Count
                                        </span>
                                    </td>
                                    <td class="pe-4">
                                        <div class="d-flex gap-1">
                                            <a asp-action="Details" asp-route-id="@listing.Id" class="btn btn-sm btn-outline-info" title="View">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@listing.Id" class="btn btn-sm btn-outline-primary" title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <form asp-action="Delete" asp-route-id="@listing.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete"
                                                        data-confirm="Delete '@listing.FoodName'? This will also delete all orders.">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <p class="text-muted mt-2 small">Showing @Model.Listings.Count listing(s)</p>
    }
</div>

@functions {
    string GetStatusClass(FoodListingStatus s) => s switch {
        FoodListingStatus.Available => "status-available",
        FoodListingStatus.PartiallyReserved or FoodListingStatus.FullyReserved => "status-reserved",
        FoodListingStatus.Completed => "status-completed",
        FoodListingStatus.Expired or FoodListingStatus.Cancelled => "status-expired",
        _ => "bg-secondary"
    };
}
