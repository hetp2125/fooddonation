@model FoodListingIndexViewModel
@{
    ViewData["Title"] = "Browse Available Food";
}

<div class="page-header">
    <div class="container">
        <h1 class="fw-bold mb-2"><i class="bi bi-search me-2"></i>Browse Available Food</h1>
        <p class="mb-0 opacity-75">@Model.Listings.Count item(s) available — find food near you and place an order.</p>
    </div>
</div>

<div class="container py-4">
    <!-- Search & Filters -->
    <div class="card border-0 shadow-sm mb-4 p-4">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label fw-semibold small">Search</label>
                <input type="text" name="search" value="@Model.SearchTerm" class="form-control" placeholder="🔍 Search food items..." />
            </div>
            <div class="col-md-3">
                <label class="form-label fw-semibold small">Category</label>
                <select name="category" class="form-select">
                    <option value="">All Categories</option>
                    @foreach (var cat in Model.Categories)
                    {
                        <option value="@cat" selected="@(Model.Category == cat)">@cat</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-semibold small">Location</label>
                <input type="text" name="location" value="@Model.Location" class="form-control" placeholder="📍 Area or address..." />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-success w-100 fw-bold">Search</button>
            </div>
        </form>
        @if (!string.IsNullOrEmpty(Model.SearchTerm) || !string.IsNullOrEmpty(Model.Category) || !string.IsNullOrEmpty(Model.Location))
        {
            <div class="mt-2">
                <a asp-action="Browse" class="btn btn-link btn-sm text-muted p-0">
                    <i class="bi bi-x-circle me-1"></i>Clear filters
                </a>
            </div>
        }
    </div>

    <!-- Category Quick Filters -->
    @if (Model.Categories.Any())
    {
        <div class="mb-4 d-flex gap-2 flex-wrap">
            <a asp-action="Browse" asp-route-search="@Model.SearchTerm" class="btn btn-sm @(string.IsNullOrEmpty(Model.Category) ? "btn-success" : "btn-outline-success") rounded-pill">
                All
            </a>
            @foreach (var cat in Model.Categories)
            {
                <a asp-action="Browse" asp-route-category="@cat" asp-route-search="@Model.SearchTerm"
                   class="btn btn-sm @(Model.Category == cat ? "btn-success" : "btn-outline-secondary") rounded-pill">
                    @GetCategoryEmoji(cat) @cat
                </a>
            }
        </div>
    }

    <!-- Results -->
    @if (!Model.Listings.Any())
    {
        <div class="empty-state card border-0 shadow-sm">
            <div class="empty-state-icon">🥗</div>
            <h5 class="mt-3 fw-bold">No food items found</h5>
            <p class="text-muted">Try adjusting your search filters or check back later.</p>
            <a asp-action="Browse" class="btn btn-outline-success">View All Items</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var listing in Model.Listings)
            {
                <div class="col-sm-6 col-lg-4">
                    <div class="card food-card shadow-sm h-100">
                        <div class="food-emoji-bg">
                            @GetCategoryEmoji(listing.Category)
                        </div>
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title fw-bold mb-0">@listing.FoodName</h5>
                                @if (listing.ExpirationDate < DateTime.UtcNow.AddDays(3))
                                {
                                    <span class="badge bg-warning text-dark">Expires Soon</span>
                                }
                            </div>

                            @if (listing.Category != null)
                            {
                                <span class="category-chip mb-2 d-inline-block">@listing.Category</span>
                            }

                            <p class="text-muted small mb-3">@listing.Description</p>

                            <div class="d-flex flex-column gap-1 text-sm">
                                <div class="d-flex align-items-center">
                                    <i class="bi bi-boxes text-success me-2"></i>
                                    <span><strong>@listing.Quantity @listing.Unit</strong> available</span>
                                </div>
                                <div class="d-flex align-items-center">
                                    <i class="bi bi-geo-alt text-danger me-2"></i>
                                    <span class="text-muted small">@listing.Location</span>
                                </div>
                                <div class="d-flex align-items-center">
                                    <i class="bi bi-calendar text-info me-2"></i>
                                    <span class="small @(listing.ExpirationDate < DateTime.UtcNow.AddDays(3) ? "expiry-soon" : "text-muted")">
                                        Expires @listing.ExpirationDate.ToString("MMM dd, yyyy")
                                    </span>
                                </div>
                                <div class="d-flex align-items-center">
                                    <i class="bi bi-person text-secondary me-2"></i>
                                    <span class="text-muted small">by @listing.Donor?.FullName</span>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-white border-0 pb-3 d-flex gap-2">
                            <a asp-action="Details" asp-route-id="@listing.Id" class="btn btn-outline-secondary btn-sm flex-shrink-0">
                                <i class="bi bi-info-circle"></i>
                            </a>
                            <a asp-controller="Orders" asp-action="PlaceOrder" asp-route-foodListingId="@listing.Id"
                               class="btn btn-success btn-sm flex-grow-1 fw-bold">
                                <i class="bi bi-cart-plus me-1"></i>Order Now
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@functions {
    string GetCategoryEmoji(string? cat) => cat switch {
        "Hot Meals" => "🍲", "Baked Goods" => "🍞", "Fresh Produce" => "🥦",
        "Pantry Items" => "🥫", "Grains" => "🌾", "Dairy" => "🧀",
        "Protein" => "🥩", "Beverages" => "🥤", _ => "🍱"
    };
}
